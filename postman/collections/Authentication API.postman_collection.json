{
  "info": {
    "_postman_id": "93ff95a0-4e7c-42c4-9112-8af147172eb6",
    "name": "Authentication API",
    "description": "End-to-end test collection for the Authentication NestJS API.\n\n**Cookie-based auth:** Login and Sign-Up set `access_token` and `refresh_token` as httpOnly cookies automatically. Postman handles these cookies natively — no manual setup needed as long as cookie handling is enabled.\n\n**Roles:** Some endpoints require the `ADMIN` role. Use the `userId` and `access_token` collection variables to track the current session.\n\nDefault port: `3000`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "id": "0a64622c-ad18-4614-9f0b-98240daee8ae",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.success && json.value) {",
                  "    pm.collectionVariables.set('userId', json.value.userId);",
                  "    pm.collectionVariables.set('accessToken', json.value.accessToken);",
                  "    console.log('userId set to', json.value.userId);",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "id": "1d645c35-6fa4-4b1f-86d5-5ebf6c63806b",
                "exec": [
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "id": "14708f7b-260b-4ef1-b9f7-c6a731b72e4e",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": {{email}},\n  \"password\": {{password}}\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "login"
              ]
            },
            "description": "Authenticates a user. On success, sets `access_token` (30d) and `refresh_token` (30d, scoped to `/auth/refresh`) as httpOnly cookies. Also returns `accessToken`, `userId`, and `expiresAt` in the response body."
          },
          "response": []
        },
        {
          "name": "Sign Up",
          "event": [
            {
              "listen": "test",
              "script": {
                "id": "823210c3-fab3-4477-85ac-20207e800132",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.success && json.value) {",
                  "    pm.collectionVariables.set('userId', json.value.userId);",
                  "    pm.collectionVariables.set('accessToken', json.value.accessToken);",
                  "    console.log('userId set to', json.value.userId);",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "id": "57f9a0b4-104b-4f16-8f01-e93b9d705bfb",
                "exec": [
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "id": "c6e75847-3ff5-4c7a-88bf-3ba1e48cd461",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": {{userName}},\n  \"email\": {{email}},\n  \"password\": {{password}},\n  \"password_confirmation\": {{password}}\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/sign-up",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "sign-up"
              ]
            },
            "description": "Registers a new user and auto-logs them in. Returns same shape as Login. Will return `403 Forbidden` if sign-up is disabled in config."
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.success && json.value) {",
                  "    pm.collectionVariables.set('accessToken', json.value.accessToken);",
                  "    console.log('accessToken refreshed, expiresAt', json.value.expiresAt);",
                  "}"
                ],
                "type": "text/javascript",
                "id": "afbcf1c1-955e-4ea9-b347-ff0fdb70ce65"
              }
            }
          ],
          "id": "5537e6c9-5e3f-423c-bbc7-0595f2e3c94c",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "refresh"
              ]
            },
            "description": "Issues a new `access_token` using the `refresh_token` cookie. No request body required — the refresh token is read from the httpOnly cookie. Returns new `accessToken` and `expiresAt`."
          },
          "response": []
        },
        {
          "name": "Logout",
          "id": "a7004c5e-722f-4091-b1e9-4fb066ae8a99",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "logout"
              ]
            },
            "description": "Requires JWT (`access_token` cookie). Invalidates the refresh token in the database and clears both cookies. Returns `{ success: true, value: { message: 'Successfully logged out' } }`."
          },
          "response": []
        }
      ],
      "id": "8576bf78-15b5-405b-80e8-c3af1a186ea2",
      "description": "Authentication endpoints — login, sign-up, token refresh, and logout. All routes are at the root level (no `/auth` prefix)."
    },
    {
      "name": "Config",
      "item": [
        {
          "name": "Get Auth Config",
          "id": "122056e6-bdfd-4fc5-ba64-84ee1decf318",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/config",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "config"
              ]
            },
            "description": "Public endpoint. Returns `{ success: true, value: { signupEnabled: boolean } }`."
          },
          "response": []
        },
        {
          "name": "Update Auth Config (Admin)",
          "id": "3ecdacf9-2cf9-43dc-b6db-c62a00f29eca",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"signupEnabled\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/config",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "config"
              ]
            },
            "description": "Requires JWT + ADMIN role. Enables or disables public user registration. Returns `{ success: true, value: { signupEnabled: boolean } }`."
          },
          "response": []
        }
      ],
      "id": "39c272b4-f5bf-4edd-a2d3-1946e7783c13",
      "description": "Auth configuration endpoints — duplicate routes exist on both the root controller and `/config`. Both are included here."
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List All Users (Admin)",
          "id": "1f962762-2d26-498e-8982-b829a0579d6c",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users"
              ]
            },
            "description": "Requires JWT + ADMIN role. Returns `{ success: boolean, value: [{ id, name, email, role }] }`."
          },
          "response": []
        },
        {
          "name": "Get User by ID",
          "id": "dc65daa7-aaed-4d64-b4af-fa59738d95ec",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/{{targetUserId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "{{targetUserId}}"
              ]
            },
            "description": "Requires JWT. Any authenticated user can call this. Returns `{ success: boolean, value: { id, name, email, role } }`."
          },
          "response": []
        },
        {
          "name": "Create User (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.success && json.value) {",
                  "    pm.collectionVariables.set('targetUserId', json.value.id);",
                  "    console.log('targetUserId set to', json.value.id);",
                  "}"
                ],
                "type": "text/javascript",
                "id": "6d446dd8-1f0b-40a3-96af-b2708fe0bdc0"
              }
            }
          ],
          "id": "075e71f1-9197-48a3-8e31-66de01862a8d",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New User\",\n  \"email\": \"newuser@example.com\",\n  \"password\": \"securepassword123\",\n  \"password_confirmation\": \"securepassword123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users"
              ]
            },
            "description": "Requires JWT + ADMIN role. Creates a new user. Returns `{ success: boolean, value: { id, name, email, role } }`."
          },
          "response": []
        },
        {
          "name": "Update User (Admin)",
          "id": "ef01ee63-a793-4600-8aec-25f6bdd1a14a",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Name\",\n  \"email\": \"updated@example.com\",\n  \"password\": \"newpassword123\",\n  \"role\": \"USER\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/users/{{targetUserId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "{{targetUserId}}"
              ]
            },
            "description": "Requires JWT + ADMIN role. All body fields are optional. `role` accepts `\"USER\"` or `\"ADMIN\"`. Returns updated user."
          },
          "response": []
        },
        {
          "name": "Update User Role (Admin)",
          "id": "d5b461c9-0129-4b10-b84e-92cf71876974",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"ADMIN\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/users/{{targetUserId}}/role",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "{{targetUserId}}",
                "role"
              ]
            },
            "description": "Requires JWT + ADMIN role. Updates only the role field. Accepted values: `\"USER\"`, `\"ADMIN\"`. Returns updated user."
          },
          "response": []
        },
        {
          "name": "Delete User by Email (Admin)",
          "id": "e00fa442-9150-48f7-b44d-5bfabb6ed0ff",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users"
              ]
            },
            "description": "Requires JWT + ADMIN role. Deletes a user by email address. Returns `{ success: boolean, value: null }`."
          },
          "response": []
        },
        {
          "name": "Create User via Auth Controller (Admin)",
          "id": "701c3b45-ba35-41c1-a3e9-8ecd7ed3abe8",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin-Created User\",\n  \"email\": \"adminmade@example.com\",\n  \"password\": \"securepassword123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users"
              ]
            },
            "description": "Alternate admin create-user endpoint on the root controller. Note: does NOT require `password_confirmation`. Returns `{ id, name, email }` (no `success` wrapper). Duplicate route — same as `POST /users` above."
          },
          "response": []
        }
      ],
      "id": "b1b3c657-5615-43b6-9048-a8446cdce1d9",
      "description": "User management endpoints. All require JWT authentication. Most require ADMIN role."
    }
  ],
